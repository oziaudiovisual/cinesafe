{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/docs-reminder.sh\"",
            "statusMessage": "Política de documentação: consulte docs/ antes de alterar"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/check-docs-sync.sh\"",
            "statusMessage": "Conferindo sincronia entre código e documentação"
          }
        ]
      }
    ]
  }
}
