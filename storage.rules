rules_version = '2';

// Regras do Cloud Storage do Cine Safe.
// Imagens de itens do marketplace e de anúncios são de leitura pública (a vitrine
// da página inicial é aberta). Notas fiscais e avatares seguem restritos a logados.
// Escrita sempre restrita ao dono da pasta (ou admin, no caso de anúncios).
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de equipamentos: leitura pública (aparecem na vitrine aberta).
    match /users/{userId}/equipment/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Imagens de anúncios: leitura pública; escrita só admin.
    match /ads/{filename} {
      allow read: if true;
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Demais arquivos do usuário (avatar, notas fiscais): só autenticados leem;
    // apenas o dono escreve na própria pasta.
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
